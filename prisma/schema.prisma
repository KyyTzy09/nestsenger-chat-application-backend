// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  userId   String  @id @default(ulid())
  email    String  @unique
  password String
  isOnline Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile      Profile?
  friends      Friend[]
  rooms        Member[]      @relation("User Rooms")
  chats        Chat[]        @relation("Chat Sender")
  reactions    Reaction[]    @relation("User Reactions")
  chatsDeleted DeletedChat[]
  Creator      Room[]        @relation("Room Creator")
  statuses     Status[]
}

model Profile {
  userId   String  @id
  avatar   String? @default("https://static.vecteezy.com/system/resources/thumbnails/047/733/682/small_2x/grey-avatar-icon-user-avatar-photo-icon-social-media-user-icon-vector.jpg")
  userName String
  bio      String? @default("Pengguna belum menambahkan info apapun")

  user     User     @relation(references: [userId], fields: [userId], onUpdate: Cascade, onDelete: Cascade)
  friendOf Friend[] @relation("Friends Of")
}

model Friend {
  id        String   @id @default(ulid())
  alias     String
  userId    String
  friendId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User?          @relation(fields: [userId], references: [userId], onUpdate: Cascade, onDelete: Cascade)
  friend        Profile?       @relation("Friends Of", fields: [friendId], references: [userId], onUpdate: Cascade, onDelete: Cascade)
  statusViewers StatusViewer[]

  @@unique([userId, friendId])
}

model Room {
  roomId      String   @id
  roomName    String?
  type        RoomType @default(PRIVATE)
  avatar      String?  @default("https://www.redcloud.us/wp-content/uploads/2020/08/Group-13.svg")
  description String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastChatId String?
  creatorId  String?
  // Relations
  members    Member[] @relation("Room Members")
  chats      Chat[]   @relation("Room Chats")
  lastChat   Chat?    @relation("Room Last Chat", fields: [lastChatId], references: [chatId], onUpdate: Cascade, onDelete: SetNull)
  createdBy  User?    @relation("Room Creator", fields: [creatorId], references: [userId])
}

model Member {
  memberId String @id @default(ulid())
  userId   String
  roomId   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  room      Room       @relation("Room Members", fields: [roomId], references: [roomId], onDelete: Cascade, onUpdate: Cascade)
  user      User       @relation("User Rooms", fields: [userId], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  readChats ChatRead[] @relation("Member Read Chat")

  @@unique([userId, roomId])
}

model Chat {
  chatId String @id @default(ulid())

  userId    String
  roomId    String
  message   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  parentId  String?

  parent       Chat?         @relation("Chat Reply", fields: [parentId], references: [chatId], onDelete: Cascade, onUpdate: Cascade)
  replies      Chat[]        @relation("Chat Reply")
  sender       User          @relation("Chat Sender", fields: [userId], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  room         Room?         @relation("Room Chats", fields: [roomId], references: [roomId], onDelete: Cascade, onUpdate: Cascade)
  media        ChatMedia?    @relation("Chat Media")
  lastChatOf   Room[]        @relation("Room Last Chat")
  reactions    Reaction[]    @relation("Chat Reactions")
  deletedChats DeletedChat[]
  readChats    ChatRead[]    @relation("Read Chat")
}

model ChatMedia {
  chatId    String   @id @default(ulid())
  mediaName String?
  mediaUrl  String
  mediaType String
  size      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chat Chat @relation("Chat Media", fields: [chatId], references: [chatId], onUpdate: Cascade, onDelete: Cascade)
}

model ChatRead {
  chatReadId String  @id @default(ulid())
  chatId     String
  readerId   String
  isRead     Boolean @default(false)

  sendAt DateTime @default(now())
  readAt DateTime @updatedAt

  chat   Chat   @relation("Read Chat", fields: [chatId], references: [chatId], onUpdate: Cascade, onDelete: Cascade)
  reader Member @relation("Member Read Chat", fields: [readerId], references: [memberId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([readerId, chatId])
}

model DeletedChat {
  userId    String
  chatId    String
  type      DeleteType
  isDeleted Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  chat Chat @relation(fields: [chatId], references: [chatId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, chatId])
}

model Reaction {
  reactionId String   @id @default(ulid())
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId String
  user   User   @relation("User Reactions", fields: [userId], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  chatId String
  chat   Chat   @relation("Chat Reactions", fields: [chatId], references: [chatId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, chatId])
}

model Status {
  statusId  String  @id @default(ulid())
  mediaName String?
  mediaUrl  String  @db.Text
  mediaType String

  createdAt DateTime @default(now())

  // Relations
  creatorId String?
  creator   User?          @relation(references: [userId], fields: [creatorId])
  viewers   StatusViewer[] @relation("Status Viewers")
}

model StatusViewer {
  viewerId String @id @default(ulid())

  statusId String?
  friendId String?
  isViewed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // Relations
  status    Status?  @relation("Status Viewers", references: [statusId], fields: [statusId], onDelete: Cascade)
  friend    Friend?  @relation(references: [id], fields: [friendId], onDelete: Cascade)

  @@unique([statusId, friendId])
}

enum RoomType {
  PRIVATE
  GROUP
}

enum DeleteType {
  SELF
  ALL
}
