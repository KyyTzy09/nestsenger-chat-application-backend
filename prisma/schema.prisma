// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  userId   String @id @default(ulid())
  email    String @unique
  password String

  profile   Profile?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  friend    Friend[]
  room      Member[]
}

model Profile {
  userId   String  @id
  avatar   String? @default("https://static.vecteezy.com/system/resources/thumbnails/047/733/682/small_2x/grey-avatar-icon-user-avatar-photo-icon-social-media-user-icon-vector.jpg")
  userName String
  bio      String? @default("Pengguna belum menambahkan info apapun")

  user     User     @relation(references: [userId], fields: [userId], onUpdate: Cascade, onDelete: Cascade)
  friendOf Friend[] @relation("Friends Of")
}

model Friend {
  id        String   @id @default(ulid())
  alias     String
  userId    String
  friendId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User?    @relation(fields: [userId], references: [userId], onUpdate: Cascade, onDelete: Cascade)
  friend Profile? @relation("Friends Of", fields: [friendId], references: [userId], onUpdate: Cascade, onDelete: Cascade)

  @@unique([userId, friendId])
}

model Room {
  roomId   String   @id
  roomName String?
  type     RoomType @default(PRIVATE)
  member   Member[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Member {
  userId String
  alias  String?
  roomId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [roomId], onDelete: Cascade, onUpdate: Cascade)
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, roomId])
}

enum RoomType {
  PRIVATE
  GROUP
}
