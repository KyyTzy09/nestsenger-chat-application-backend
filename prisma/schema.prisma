// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  userId   String @id @default(ulid())
  email    String @unique
  password String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile   Profile?
  friends   Friend[]
  rooms     Member[]   @relation("User Rooms")
  chats     Chat[]     @relation("Chat Sender")
  reactions Reaction[] @relation("User Reactions")
}

model Profile {
  userId   String  @id
  avatar   String? @default("https://static.vecteezy.com/system/resources/thumbnails/047/733/682/small_2x/grey-avatar-icon-user-avatar-photo-icon-social-media-user-icon-vector.jpg")
  userName String
  bio      String? @default("Pengguna belum menambahkan info apapun")

  user     User     @relation(references: [userId], fields: [userId], onUpdate: Cascade, onDelete: Cascade)
  friendOf Friend[] @relation("Friends Of")
}

model Friend {
  id        String   @id @default(ulid())
  alias     String
  userId    String
  friendId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User?    @relation(fields: [userId], references: [userId], onUpdate: Cascade, onDelete: Cascade)
  friend Profile? @relation("Friends Of", fields: [friendId], references: [userId], onUpdate: Cascade, onDelete: Cascade)

  @@unique([userId, friendId])
}

model Room {
  roomId   String   @id
  roomName String?
  type     RoomType @default(PRIVATE)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastChatId String?
  // Relations
  members    Member[] @relation("Room Members")
  chats      Chat[]   @relation("Room Chats")
  lastChat   Chat?    @relation("Room Last Chat", fields: [lastChatId], references: [chatId], onUpdate: Cascade, onDelete: Cascade)
}

model Chat {
  chatId String @id @default(ulid())

  userId    String
  roomId    String
  message   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  parentId  String?

  parent     Chat?      @relation("Chat Reply", fields: [parentId], references: [chatId], onDelete: Cascade, onUpdate: Cascade)
  replies    Chat[]     @relation("Chat Reply")
  sender     User       @relation("Chat Sender", fields: [userId], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  room       Room?      @relation("Room Chats", fields: [roomId], references: [roomId], onDelete: Cascade, onUpdate: Cascade)
  lastChatOf Room[]     @relation("Room Last Chat")
  reactions  Reaction[] @relation("Chat Reactions")
}

model Reaction {
  reactionId String   @id @default(ulid())
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId String
  user   User   @relation("User Reactions", fields: [userId], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  chatId String
  chat   Chat   @relation("Chat Reactions", fields: [chatId], references: [chatId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, chatId])
}

model Member {
  userId String
  roomId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  room Room @relation("Room Members", fields: [roomId], references: [roomId], onDelete: Cascade, onUpdate: Cascade)
  user User @relation("User Rooms", fields: [userId], references: [userId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, roomId])
}

enum RoomType {
  PRIVATE
  GROUP
}
